<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.WagesMapper">

    <select id="selectAll" resultType="com.example.entity.Wages">
        select `wages`.*, `employee`.`username` as card from `wages`
		left join `employee` on `wages`.`employee_id` = `employee`.id

        <where>
			<if test="card != null and card != ''">
				and `employee`.`username` like concat ('%', #{card}, '%')
			</if>
			<if test="employeeName != null and employeeName != ''">
				and `wages`.`e_name` like concat ('%', #{employeeName}, '%')
			</if>
			<if test="employeeId != null">
				and `wages`.`employee_id` = #{employeeId}
			</if>

        </where>
    </select>

    <select id="selectById" resultType="com.example.entity.Wages">
        select * from wages where id = #{id}
    </select>

    <delete id="deleteById">
        delete from wages where  id = #{id}
    </delete>

</mapper>